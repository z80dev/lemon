#!/usr/bin/env bash
# Canonical Lemon repo-level test runner.
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
LANE="${1:-help}"
if [ "$#" -gt 0 ]; then
  shift
fi

SCRUB_CREDENTIAL_ENV_VARS=(
  AI21_API_KEY
  ANTHROPIC_API_KEY
  ANTHROPIC_TOKEN
  AWS_ACCESS_KEY_ID
  AWS_PROFILE
  AWS_SECRET_ACCESS_KEY
  AWS_SESSION_TOKEN
  AZURE_OPENAI_API_KEY
  BRAVE_API_KEY
  CHATGPT_TOKEN
  CLAUDE_CODE_OAUTH_TOKEN
  DEEPGRAM_API_KEY
  DINGTALK_BOT_TOKEN
  DISCORD_BOT_TOKEN
  ELEVENLABS_API_KEY
  FEISHU_APP_SECRET
  FEISHU_BOT_TOKEN
  FIREWORKS_API_KEY
  GEMINI_API_KEY
  GH_TOKEN
  GITHUB_COPILOT_API_KEY
  GITHUB_TOKEN
  GOOGLE_API_KEY
  GOOGLE_APPLICATION_CREDENTIALS
  GOOGLE_APPLICATION_CREDENTIALS_JSON
  GOOGLE_CLOUD_PROJECT
  GOOGLE_CLOUD_PROJECT_ID
  GOOGLE_GENERATIVE_AI_API_KEY
  GOOGLE_GEMINI_CLI_API_KEY
  GROQ_API_KEY
  KIMI_API_KEY
  LEMON_EVAL_API_KEY
  LEMON_EVAL_API_KEY_SECRET
  LEMON_SECRETS_MASTER_KEY
  MINIMAX_API_KEY
  MISTRAL_API_KEY
  MOONSHOT_API_KEY
  NOUS_API_KEY
  OPENAI_API_KEY
  OPENAI_CODEX_API_KEY
  OPENCODE_API_KEY
  OPENROUTER_API_KEY
  INTEGRATION_API_KEY
  INTEGRATION_API_KEY_SECRET
  SLACK_APP_TOKEN
  SLACK_BOT_TOKEN
  TELEGRAM_BOT_TOKEN
  TWILIO_AUTH_TOKEN
  XAI_API_KEY
  X_API_ACCESS_TOKEN
  X_API_ACCESS_TOKEN_SECRET
  X_API_BEARER_TOKEN
  X_API_CLIENT_ID
  X_API_CLIENT_SECRET
  X_API_CONSUMER_KEY
  X_API_CONSUMER_SECRET
  X_API_REFRESH_TOKEN
  X_BEARER_TOKEN
  XMTP_WALLET_KEY
  ZAI_API_KEY
)

usage() {
  cat <<'EOF'
Usage: scripts/test <lane> [args]

Canonical test lanes:
  fast       MIX_ENV=test compile with warnings as errors, then ExUnit excluding integration
  quality    Lemon quality gates: CI/docs lint, skill lint, architecture quality, duplicate tests, focused quality tests
  clients    Client CI parity checks for lemon-web, lemon-tui, lemon-browser-node, and lemon-cli
  eval-fast  Small deterministic eval harness run: mix lemon.eval --iterations ${LEMON_EVAL_ITERATIONS:-3}
  live-eval  Opt-in provider-backed eval run: mix lemon.eval --live-model --iterations ${LEMON_EVAL_ITERATIONS:-3}
  smoke      Local product-smoke pointer; CI-only release smoke is in .github/workflows/product-smoke.yml
  all        Useful local aggregate: fast, quality, eval-fast, smoke
  path       Pass-through to mix test for paths or ExUnit args: scripts/test path apps/foo/test --seed 1
  help       Show this message

Runner defaults:
  - Runs from the repository root.
  - Sets MIX_ENV=test for BEAM test lanes unless a lane intentionally overrides it.
  - Creates per-invocation temp LEMON_STORE_PATH and LEMON_TEST_TMPDIR when unset.
  - BEAM test lanes scrub ambient provider/platform credentials unless LEMON_TEST_ALLOW_LIVE_CREDENTIALS=1.
  - Client lanes run npm ci by default; set LEMON_TEST_REUSE_NODE_MODULES=1 to reuse existing installs.
EOF
}

ensure_repo_root() {
  cd "$ROOT"
}

setup_test_env() {
  export MIX_ENV="${MIX_ENV:-test}"
  scrub_live_credentials
  setup_tmp_env
}

setup_live_eval_env() {
  export MIX_ENV="${MIX_ENV:-test}"
  setup_tmp_env
}

resolve_live_eval_secret_ref() {
  local target_env="$1"
  local secret_env="$2"

  if [ -n "${!target_env:-}" ] || [ -z "${!secret_env:-}" ]; then
    return 0
  fi

  local resolved
  local secret_file
  secret_file="$(mktemp "${TMPDIR:-/tmp}/lemon-live-eval-secret.XXXXXX")"

  if ! LEMON_SECRET_NAME="${!secret_env}" LEMON_SECRET_OUTPUT="$secret_file" MIX_ENV=dev mix run --no-start -e '
      Logger.configure(level: :emergency)
      Logger.remove_backend(:console)

      {:ok, _} = Application.ensure_all_started(:lemon_core)
      name = System.fetch_env!("LEMON_SECRET_NAME")
      output = System.fetch_env!("LEMON_SECRET_OUTPUT")

      case LemonCore.Secrets.fetch_value(name) do
        value when is_binary(value) and value != "" ->
          File.write!(output, value)

        _ ->
          System.halt(66)
      end
    ' >/dev/null 2>&1; then
    rm -f "$secret_file"
    cat >&2 <<EOF
scripts/test live-eval could not resolve $secret_env from Lemon secrets.
EOF
    exit 66
  fi

  resolved="$(cat "$secret_file")"
  rm -f "$secret_file"

  export "$target_env=$resolved"
}

setup_tmp_env() {
  if [ -z "${LEMON_TEST_TMPDIR:-}" ]; then
    export LEMON_TEST_TMPDIR="$(mktemp -d "${TMPDIR:-/tmp}/lemon-test.XXXXXX")"
    trap 'rm -rf "$LEMON_TEST_TMPDIR"' EXIT
  fi

  export LEMON_STORE_PATH="${LEMON_STORE_PATH:-$LEMON_TEST_TMPDIR/store}"
  mkdir -p "$LEMON_STORE_PATH"
}

scrub_live_credentials() {
  case "${LEMON_TEST_ALLOW_LIVE_CREDENTIALS:-}" in
    1|true|TRUE|yes|YES) return 0 ;;
  esac

  local key
  for key in "${SCRUB_CREDENTIAL_ENV_VARS[@]}"; do
    unset "$key"
  done
}

run_fast() {
  ensure_repo_root
  setup_test_env
  mix compile --warnings-as-errors
  mix test --exclude integration "$@"
}

run_quality() {
  ensure_repo_root
  setup_test_env
  bash scripts/lint_ci_docs.sh
  bash scripts/test_contract.sh
  mix lemon.skill.lint
  mix lemon.quality
  mix test apps/lemon_core/test/lemon_core/quality apps/lemon_evals/test/lemon_evals/harness_test.exs
}

run_npm_ci_if_needed() {
  local dir="$1"
  if [ "${LEMON_TEST_REUSE_NODE_MODULES:-}" != "1" ] || [ ! -d "$dir/node_modules" ]; then
    (cd "$dir" && npm ci)
  fi
}

run_clients() {
  ensure_repo_root

  (cd clients/lemon-cli &&
    uv sync --locked --dev &&
    uv run ruff check src tests &&
    uv run pytest &&
    tmpdir="$(mktemp -d)" &&
    trap 'rm -rf "$tmpdir"' EXIT &&
    uv build --sdist --wheel --out-dir "$tmpdir")

  run_npm_ci_if_needed clients/lemon-web
  (cd clients/lemon-web && npm run typecheck && npm --workspace web run lint && npm run build && npm run test:coverage && npm audit --omit=dev --audit-level=high)

  run_npm_ci_if_needed clients/lemon-tui
  (cd clients/lemon-tui && npm run typecheck && npm run lint && npm run build && npm run test:coverage && npm audit --omit=dev --audit-level=high)

  run_npm_ci_if_needed clients/lemon-browser-node
  (cd clients/lemon-browser-node && npm run typecheck && npm run lint && npm run build && npm run test:coverage && npm audit --omit=dev --audit-level=high)
}

run_eval_fast() {
  ensure_repo_root
  setup_test_env
  mix lemon.eval --iterations "${LEMON_EVAL_ITERATIONS:-3}" "$@"
}

run_live_eval() {
  ensure_repo_root
  resolve_live_eval_secret_ref LEMON_EVAL_API_KEY LEMON_EVAL_API_KEY_SECRET
  resolve_live_eval_secret_ref INTEGRATION_API_KEY INTEGRATION_API_KEY_SECRET
  setup_live_eval_env

  if [ -z "${LEMON_EVAL_API_KEY:-}" ] &&
     [ -z "${LEMON_EVAL_API_KEY_SECRET:-}" ] &&
     [ -z "${INTEGRATION_API_KEY:-}" ] &&
     [ -z "${INTEGRATION_API_KEY_SECRET:-}" ] &&
     [ -z "${ANTHROPIC_API_KEY:-}" ]; then
    cat >&2 <<'EOF'
scripts/test live-eval requires a live model credential.

Set one of:
  LEMON_EVAL_API_KEY
  LEMON_EVAL_API_KEY_SECRET
  INTEGRATION_API_KEY
  INTEGRATION_API_KEY_SECRET
  ANTHROPIC_API_KEY

Optional live eval configuration:
  LEMON_EVAL_PROVIDER
  LEMON_EVAL_MODEL
  LEMON_EVAL_BASE_URL
  LEMON_EVAL_API_TYPE
EOF
    exit 66
  fi

  mix lemon.eval --live-model --iterations "${LEMON_EVAL_ITERATIONS:-3}" "$@"
}

run_smoke() {
  ensure_repo_root
  cat <<'EOF'
The product smoke lane is CI-only for now because it builds and boots a release
with GitHub Actions service assumptions. Use one of:

  gh workflow run product-smoke.yml
  scripts/test fast
  scripts/test quality

Canonical CI smoke definition: .github/workflows/product-smoke.yml
EOF
}

run_path() {
  ensure_repo_root
  setup_test_env
  if [ "$#" -eq 0 ]; then
    echo "scripts/test path requires at least one mix test path or argument" >&2
    exit 64
  fi
  mix test "$@"
}

case "$LANE" in
  help|-h|--help) usage ;;
  fast) run_fast "$@" ;;
  quality) run_quality "$@" ;;
  clients) run_clients "$@" ;;
  eval-fast) run_eval_fast "$@" ;;
  live-eval) run_live_eval "$@" ;;
  smoke) run_smoke "$@" ;;
  all)
    run_fast
    run_quality
    run_eval_fast
    run_smoke
    ;;
  path) run_path "$@" ;;
  *)
    echo "Unknown test lane: $LANE" >&2
    usage >&2
    exit 64
    ;;
esac
