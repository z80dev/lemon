verify_terminal_backend_proof() {
  local proof_path="${LEMON_TERMINAL_BACKEND_PROOF_JSON:-.lemon/proofs/terminal-backend-latest.json}"

  if [ ! -f "$proof_path" ]; then
    block "terminal backend proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
results = data.get("results") or []
by_backend = {
    row.get("backend"): row
    for row in results
    if isinstance(row, dict) and row.get("backend")
}
required = {"local", "local_pty", "docker", "ssh"}
missing = sorted(required - set(by_backend))
failed = sorted(
    backend
    for backend in required & set(by_backend)
    if by_backend[backend].get("status") != "completed"
)
cleanup = data.get("cleanup") or {}
bad_cleanup = [
    key
    for key in ("includes_commands", "includes_environment", "includes_process_output")
    if cleanup.get(key) is not False
]

if (
    data.get("status") != "completed"
    or data.get("failed_count") != 0
    or missing
    or failed
    or bad_cleanup
):
    if data.get("status") != "completed":
        print(f"terminal backend proof status is {data.get('status')}", file=sys.stderr)
    if data.get("failed_count") != 0:
        print(f"terminal backend proof failed_count is {data.get('failed_count')}", file=sys.stderr)
    if missing:
        print(f"terminal backend proof missing rows: {', '.join(missing)}", file=sys.stderr)
    if failed:
        print(f"terminal backend proof incomplete rows: {', '.join(failed)}", file=sys.stderr)
    if bad_cleanup:
        print(f"terminal backend proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "terminal backend proof is present"
  else
    case "$?" in
      66) block "terminal backend proof is missing completed live evidence" ;;
      *) fail "terminal backend proof is unreadable" ;;
    esac
  fi
}

cd "$ROOT"

if ! echo "$VERSION" | grep -qE '^[0-9]{4}\.[0-9]{1,2}\.[0-9]+$'; then
  echo "invalid CalVer version: $VERSION" >&2
  exit 2
fi

MIX_VERSION="$(
  python3 - <<'PY'
import re
from pathlib import Path

match = re.search(r'version:\s*"([^"]+)"', Path("mix.exs").read_text(encoding="utf-8"))
print(match.group(1) if match else "")
PY
)"

if [ "$MIX_VERSION" = "$VERSION" ]; then
  pass "mix.exs version matches $VERSION"
else
  fail "mix.exs version is '$MIX_VERSION', expected '$VERSION'"
fi

run_or_fail "release notes are valid for $VERSION" \
  scripts/prepare_release_notes "$VERSION"

run_or_fail "CI/docs policy lint passes" \
  scripts/lint_ci_docs.sh

run_or_fail "fast test lane passes" \
  scripts/test fast

run_or_fail "quality test lane passes" \
  scripts/test quality

run_or_fail "eval-fast test lane passes" \
  scripts/test eval-fast

run_or_fail "client test lane passes" \
  scripts/test clients

run_or_fail "docs site verifies" \
  scripts/verify_docs_site

verify_public_support_boundaries
verify_channel_command_matrix

if [ -n "$LOCAL_ARTIFACT_DIR" ]; then
  run_or_fail "local artifacts verify and boot at $LOCAL_ARTIFACT_DIR" \
    scripts/verify_release_runtime_boot "$LOCAL_ARTIFACT_DIR"
else
  block "local artifact verification not run; pass the artifact directory as the second argument"
fi

if [ -n "${LEMON_EVAL_API_KEY:-}" ] ||
   [ -n "${LEMON_EVAL_API_KEY_SECRET:-}" ] ||
   [ -n "${INTEGRATION_API_KEY:-}" ] ||
   [ -n "${INTEGRATION_API_KEY_SECRET:-}" ] ||
   [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  run_or_fail "provider-backed live eval passes" \
    scripts/test live-eval
else
  block "provider-backed live eval not run; set LEMON_EVAL_API_KEY, LEMON_EVAL_API_KEY_SECRET, INTEGRATION_API_KEY, INTEGRATION_API_KEY_SECRET, or ANTHROPIC_API_KEY"
fi

verify_discord_live_proof
verify_discord_live_redacted_proof
verify_discord_media_slash_proof
verify_discord_media_slash_redacted_proof
verify_discord_rollback_slash_proof
verify_discord_rollback_slash_redacted_proof
verify_discord_all_slash_proof
verify_discord_all_slash_redacted_proof
verify_discord_dm_redacted_proof
verify_discord_free_response_redacted_proof
verify_discord_slash_client_click_proof
verify_media_directive_redacted_proofs
verify_media_provider_proofs
verify_browser_proof
verify_openai_compat_proof
verify_acp_proofs
verify_mcp_proofs
verify_lsp_proofs
verify_extension_proofs
verify_cron_proofs
verify_terminal_backend_proof

echo ""

if [ "$ERRORS" -gt 0 ]; then
  echo "FAILED: $ERRORS readiness failure(s), $BLOCKERS blocker(s)." >&2
  exit 1
fi

if [ "$BLOCKERS" -gt 0 ]; then
  echo "BLOCKED: $BLOCKERS launch-blocking evidence item(s) missing." >&2
  print_blocker_next_steps
  exit 66
fi

echo "Lemon $VERSION readiness audit passed."
