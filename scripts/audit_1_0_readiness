verify_mcp_proof() {
  local label="$1"
  local proof_path="$2"
  local proof_name="$3"
  local required_count="$4"
  local required_rows_csv="$5"

  if [ ! -f "$proof_path" ]; then
    block "MCP $label proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$proof_name" "$required_count" "$required_rows_csv" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
expected_proof = sys.argv[2]
required_count = int(sys.argv[3])
required = set(filter(None, sys.argv[4].split(",")))

data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
by_name = {
    row.get("name"): row
    for row in checks
    if isinstance(row, dict) and row.get("name")
}
missing = sorted(required - set(by_name))
failed = sorted(
    name
    for name in required & set(by_name)
    if by_name[name].get("status") != "completed"
)
cleanup = data.get("cleanup") or {}
bad_cleanup = [
    key
    for key in (
        "includes_raw_paths",
        "includes_raw_filenames",
        "includes_raw_prompts",
        "includes_raw_provider_responses",
        "includes_raw_tool_arguments",
        "includes_raw_tool_results",
        "includes_server_io",
    )
    if cleanup.get(key) is not False
]

if (
    data.get("proof") != expected_proof
    or data.get("status") != "completed"
    or data.get("completed_count") != required_count
    or data.get("failed_count") != 0
    or data.get("skipped_count") != 0
    or missing
    or failed
    or bad_cleanup
):
    if data.get("proof") != expected_proof:
        print(f"MCP proof name is {data.get('proof')}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"MCP proof status is {data.get('status')}", file=sys.stderr)
    if (
        data.get("completed_count") != required_count
        or data.get("failed_count") != 0
        or data.get("skipped_count") != 0
    ):
        print(
            f"MCP proof counts are completed_count={data.get('completed_count')} failed_count={data.get('failed_count')} skipped_count={data.get('skipped_count')}",
            file=sys.stderr,
        )
    if missing:
        print(f"MCP proof missing rows: {', '.join(missing)}", file=sys.stderr)
    if failed:
        print(f"MCP proof incomplete rows: {', '.join(failed)}", file=sys.stderr)
    if bad_cleanup:
        print(f"MCP proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "MCP $label proof is present"
  else
    case "$?" in
      66) block "MCP $label proof is missing completed local evidence" ;;
      *) fail "MCP $label proof is unreadable" ;;
    esac
  fi
}

