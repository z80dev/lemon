verify_acp_proof() {
  local label="$1"
  local proof_path="$2"
  local object="$3"
  local required_count="$4"
  local required_rows_csv="$5"
  local expected_updates="${6:-}"
  local expected_client_requests="${7:-}"

  if [ ! -f "$proof_path" ]; then
    block "ACP $label proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$object" "$required_count" "$required_rows_csv" "$expected_updates" "$expected_client_requests" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
expected_object = sys.argv[2]
required_count = int(sys.argv[3])
required = {item for item in sys.argv[4].split(",") if item}
expected_updates = sys.argv[5]
expected_client_requests = sys.argv[6]
data = json.loads(path.read_text(encoding="utf-8"))
results = data.get("results") or []
by_name = {
    row.get("name"): row
    for row in results
    if isinstance(row, dict) and row.get("name")
}
missing = sorted(required - set(by_name))
failed = sorted(
    name
    for name in required & set(by_name)
    if by_name[name].get("status") != "completed"
)
cleanup = data.get("cleanup") or {}
bad_cleanup = [
    key
    for key in (
        "includes_raw_prompts",
        "includes_raw_api_keys",
        "includes_raw_answers",
        "includes_raw_events",
        "includes_raw_session_ids",
        "includes_child_stderr",
        "includes_raw_file_contents",
        "includes_raw_file_paths",
    )
    if key in cleanup and cleanup.get(key) is not False
]
bad_updates = expected_updates and data.get("update_count") != int(expected_updates)
bad_client_requests = expected_client_requests and data.get("client_request_count") != int(expected_client_requests)

if (
    data.get("object") != expected_object
    or data.get("completed_count") != required_count
    or data.get("failed_count") != 0
    or missing
    or failed
    or bad_cleanup
    or bad_updates
    or bad_client_requests
):
    if data.get("object") != expected_object:
        print(f"ACP proof object is {data.get('object')}", file=sys.stderr)
    if data.get("completed_count") != required_count or data.get("failed_count") != 0:
        print(
            f"ACP proof counts are completed_count={data.get('completed_count')} failed_count={data.get('failed_count')}",
            file=sys.stderr,
        )
    if missing:
        print(f"ACP proof missing rows: {', '.join(missing)}", file=sys.stderr)
    if failed:
        print(f"ACP proof incomplete rows: {', '.join(failed)}", file=sys.stderr)
    if bad_cleanup:
        print(f"ACP proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if bad_updates:
        print(f"ACP proof update_count is {data.get('update_count')}", file=sys.stderr)
    if bad_client_requests:
        print(f"ACP proof client_request_count is {data.get('client_request_count')}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "ACP $label proof is present"
  else
    case "$?" in
      66) block "ACP $label proof is missing completed local evidence" ;;
      *) fail "ACP $label proof is unreadable" ;;
    esac
  fi
}

