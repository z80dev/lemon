verify_cron_proof() {
  local label="$1"
  local proof_path="$2"
  local expected_object="$3"
  local object_key="$4"
  local required_count="$5"
  local required_rows_csv="$6"
  local cleanup_keys_csv="$7"

  if [ ! -f "$proof_path" ]; then
    block "cron $label proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$expected_object" "$object_key" "$required_count" "$required_rows_csv" "$cleanup_keys_csv" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
expected_object = sys.argv[2]
object_key = sys.argv[3]
required_count = int(sys.argv[4])
required = set(filter(None, sys.argv[5].split(",")))
cleanup_keys = tuple(filter(None, sys.argv[6].split(",")))

data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
by_name = {
    row.get("name"): row
    for row in checks
    if isinstance(row, dict) and row.get("name")
}
missing = sorted(required - set(by_name))
failed = sorted(
    name
    for name in required & set(by_name)
    if by_name[name].get("status") != "completed"
)
cleanup = data.get("cleanup") or {}
bad_cleanup = [key for key in cleanup_keys if cleanup.get(key) is not False]
actual_object = data.get(object_key)
proof_status = data.get("status")
checks_completed = not missing and not failed
status_ok = proof_status == "completed" or (proof_status is None and checks_completed)

if (
    actual_object != expected_object
    or not status_ok
    or data.get("completed_count") != required_count
    or data.get("failed_count") != 0
    or (data.get("skipped_count") or 0) != 0
    or missing
    or failed
    or bad_cleanup
):
    if actual_object != expected_object:
        print(f"cron proof object is {actual_object}", file=sys.stderr)
    if not status_ok:
        print(f"cron proof status is {proof_status}", file=sys.stderr)
    if data.get("completed_count") != required_count or data.get("failed_count") != 0 or (data.get("skipped_count") or 0) != 0:
        print(
            f"cron proof counts are completed_count={data.get('completed_count')} failed_count={data.get('failed_count')} skipped_count={data.get('skipped_count')}",
            file=sys.stderr,
        )
    if missing:
        print(f"cron proof missing rows: {', '.join(missing)}", file=sys.stderr)
    if failed:
        print(f"cron proof incomplete rows: {', '.join(failed)}", file=sys.stderr)
    if bad_cleanup:
        print(f"cron proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "cron $label proof is present"
  else
    case "$?" in
      66) block "cron $label proof is missing completed local evidence" ;;
      *) fail "cron $label proof is unreadable" ;;
    esac
  fi
}

