  if [ -z "$proof_path" ]; then
    block "Discord all-command slash schema not verified; set LEMON_DISCORD_ALL_SLASH_PROOF_JSON to a passing result JSON"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord all-command slash schema result file is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
check = next((row for row in checks if row.get("name") == "discord_all_slash_registration"), None)

if data.get("ok") is not True or not check or check.get("ok") is not True:
    print("Discord all-command slash proof is missing or failed", file=sys.stderr)
    sys.exit(66)

expected = check.get("expected_command_count")
registered = check.get("registered_command_count")
missing = check.get("missing_commands") or []

if expected != 16 or registered < expected or missing:
    print("Discord all-command slash proof does not show all expected command names", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord all-command slash schema proof is present"
  else
    case "$?" in
      66) block "Discord all-command slash schema result does not prove required checks" ;;
      *) fail "Discord all-command slash schema result is unreadable" ;;
    esac
  fi
}

