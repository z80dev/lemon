verify_media_directive_redacted_proof() {
  local label="$1"
  local proof_path="$2"
  local proof_object="$3"
  local check_name="$4"
  local required_cleanup_csv="$5"

  if [ ! -f "$proof_path" ]; then
    block "$label MEDIA directive redacted proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$proof_object" "$check_name" "$required_cleanup_csv" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
proof_object = sys.argv[2]
check_name = sys.argv[3]
required_cleanup = [key for key in sys.argv[4].split(",") if key]

data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
check = next((row for row in checks if row.get("name") == check_name), None)
coverage = data.get("coverage") or {}
cleanup = data.get("cleanup") or {}
bad_cleanup = [key for key in required_cleanup if cleanup.get(key) is not False]

attachment_ok = False

if check:
    marker_seen = check.get("marker_seen") is True
    if check.get("telegram_has_document") is True:
        attachment_ok = True
    if (check.get("attachment_count") or 0) >= 1:
        attachment_ok = True

if (
    data.get("status") != "completed"
    or data.get("proof_object") != proof_object
    or not check
    or check.get("status") != "completed"
    or coverage.get("contains_media_directive") is not True
    or check.get("directive_leaked") is not False
    or not marker_seen
    or not attachment_ok
    or bad_cleanup
):
    if data.get("status") != "completed":
        print(f"MEDIA directive proof status is {data.get('status')}", file=sys.stderr)
    if data.get("proof_object") != proof_object:
        print(f"MEDIA directive proof_object is {data.get('proof_object')}", file=sys.stderr)
    if not check or check.get("status") != "completed":
        print(f"MEDIA directive check {check_name} is missing or not completed", file=sys.stderr)
    if coverage.get("contains_media_directive") is not True:
        print("MEDIA directive proof is missing contains_media_directive coverage", file=sys.stderr)
    if check and check.get("directive_leaked") is not False:
        print("MEDIA directive proof did not prove directive leak suppression", file=sys.stderr)
    if not marker_seen:
        print("MEDIA directive proof marker was not observed", file=sys.stderr)
    if not attachment_ok:
        print("MEDIA directive proof did not show a delivered document or attachment", file=sys.stderr)
    if bad_cleanup:
        print(f"MEDIA directive proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "$label MEDIA directive redacted proof is present"
  else
    case "$?" in
      66) block "$label MEDIA directive redacted proof does not prove final-answer attachment delivery" ;;
      *) fail "$label MEDIA directive redacted proof is unreadable" ;;
    esac
  fi
}

verify_media_directive_redacted_proofs() {
  verify_media_directive_redacted_proof \
    "Telegram" \
    "${LEMON_TELEGRAM_MEDIA_DIRECTIVE_REDACTED_PROOF_JSON:-.lemon/proofs/telegram-media-directive-latest.json}" \
    "lemon.telegram_live_matrix" \
    "telegram_forum_topic_media_directive_delivery" \
    "includes_raw_bot_tokens,includes_raw_chat_ids,includes_raw_user_ids,includes_raw_message_bodies,includes_secret_names"

  verify_media_directive_redacted_proof \
    "Discord" \
    "${LEMON_DISCORD_MEDIA_DIRECTIVE_REDACTED_PROOF_JSON:-.lemon/proofs/discord-media-directive-latest.json}" \
    "lemon.discord_live_matrix" \
    "discord_media_directive_delivery" \
    "includes_raw_bot_tokens,includes_raw_interaction_tokens,includes_raw_application_ids,includes_raw_channel_ids,includes_raw_user_ids,includes_raw_message_bodies,includes_secret_names"
}

verify_media_provider_proof() {
  local label="$1"
  local proof_path="$2"
  local provider="$3"
  local proof_object="$4"
  local check_name="$5"

  if [ ! -f "$proof_path" ]; then
    block "provider-backed $label media proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$provider" "$proof_object" "$check_name" "$label" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
providers = [item for item in sys.argv[2].split("|") if item]
proof_object = sys.argv[3]
check_names = [item for item in sys.argv[4].split("|") if item]
label = sys.argv[5]
data = json.loads(path.read_text(encoding="utf-8"))
details = data.get("details") or {}
checks = data.get("checks") or []
cleanup = data.get("cleanup") or {}
check = next((row for row in checks if row.get("name") in check_names), None)
bad_cleanup = [key for key, value in cleanup.items() if key.startswith("includes_raw_") and value is not False]
safe_reason_label = re.compile(r"^[A-Za-z0-9_.:-]{1,80}$")


def reason_kind(value):
    if not isinstance(value, str) or not value:
        return None

    if safe_reason_label.match(value):
        return value

    return "unsafe_reason_kind_redacted"


def reason_hint(kind):
    if not kind:
        return None

    if "permission_denied" in kind:
        return "provider permissions were denied; enable the API and grant IAM/billing access for the configured provider account"
    if "billing_limit" in kind:
        return "provider billing or quota limit was hit; use a funded project/key or raise quota"
    if "payment_required" in kind:
        return "provider payment is required; fund or upgrade the account"
    if "invalid_request_error" in kind:
        return "provider rejected the request; verify model, voice, output format, and provider options"
    if "provider_http_error" in kind:
        return "provider returned an HTTP error; inspect the sanitized reason and rerun the target provider lane"

    return None


def script_for_label(value):
    return {
        "image": "scripts/live_media_image_smoke.exs",
        "TTS": "scripts/live_media_speech_smoke.exs",
        "STT": "scripts/live_media_transcription_smoke.exs",
        "vision": "scripts/live_media_vision_smoke.exs",
        "video": "scripts/live_media_video_smoke.exs",
    }.get(value)


check_details = check.get("details") if isinstance(check, dict) and isinstance(check.get("details"), dict) else {}
reason_kinds = sorted(
    {
        kind
        for kind in (
            reason_kind(data.get("reason_kind")),
            reason_kind(details.get("reason_kind")),
            reason_kind(check.get("reason_kind")) if isinstance(check, dict) else None,
            reason_kind(check_details.get("reason_kind")),
        )
        if kind
    }
)

if (
    data.get("status") != "completed"
    or data.get("completed_count") != 1
    or data.get("failed_count") != 0
    or data.get("proof_object") != proof_object
    or data.get("proof_scope") != "media_provider"
    or details.get("provider") not in providers
    or not check
    or check.get("status") != "completed"
    or check.get("proof_scope") != "media_provider"
    or bad_cleanup
):
    if data.get("status") != "completed":
        print(f"media proof status is {data.get('status')}", file=sys.stderr)
    if data.get("completed_count") != 1 or data.get("failed_count") != 0:
        print("media proof count shape is not completed_count=1 failed_count=0", file=sys.stderr)
    if data.get("proof_object") != proof_object:
        print(f"media proof_object is {data.get('proof_object')}", file=sys.stderr)
    if data.get("proof_scope") != "media_provider":
        print(f"media proof_scope is {data.get('proof_scope')}", file=sys.stderr)
    if details.get("provider") not in providers:
        print(f"media proof provider is {details.get('provider')}", file=sys.stderr)
    if not check or check.get("status") != "completed" or check.get("proof_scope") != "media_provider":
        print(f"media proof check {' or '.join(check_names)} is missing or not completed", file=sys.stderr)
    if bad_cleanup:
        print(f"media proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if reason_kinds:
        print(f"media proof reason_kind: {', '.join(reason_kinds)}", file=sys.stderr)
        hints = sorted({hint for hint in map(reason_hint, reason_kinds) if hint})
        if hints:
            print(f"media proof remediation hint: {'; '.join(hints)}", file=sys.stderr)
    provider = details.get("provider")
    script = script_for_label(label)
    if script and provider in providers and len(providers) > 1:
        print(
            f"media proof rerun command: LEMON_TEST_ALLOW_LIVE_CREDENTIALS=1 MIX_ENV=test mix run --no-start {script} --proof-path {path} --provider {provider}",
            file=sys.stderr,
        )
    sys.exit(66)

print("ok")
PY
  then
    pass "provider-backed $label media proof is present"
  else
    case "$?" in
      66) block "provider-backed $label media proof is missing completed live evidence" ;;
      *) fail "provider-backed $label media proof is unreadable" ;;
    esac
  fi
}

