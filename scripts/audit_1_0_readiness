verify_lsp_proof() {
  local label="$1"
  local proof_path="$2"
  local proof_name="$3"

  if [ ! -f "$proof_path" ]; then
    block "LSP $label proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$proof_name" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
expected_proof = sys.argv[2]
servers = {
    "pyright",
    "gopls",
    "clangd",
    "rust_analyzer",
    "typescript_language_server",
    "elixir_ls",
}
required = {f"{expected_proof}_{server}_editor_flow" for server in servers}
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
by_name = {
    row.get("name"): row
    for row in checks
    if isinstance(row, dict) and row.get("name")
}
missing = sorted(required - set(by_name))
failed = sorted(
    name
    for name in required & set(by_name)
    if by_name[name].get("status") != "completed"
)
cleanup = data.get("cleanup") or {}
bad_cleanup = [
    key
    for key in (
        "includes_raw_paths",
        "includes_file_contents",
        "includes_diagnostics_output",
        "includes_raw_session_ids",
        "includes_server_io",
    )
    if cleanup.get(key) is not False
]

if (
    data.get("proof") != expected_proof
    or data.get("status") != "completed"
    or data.get("completed_count") != len(servers)
    or data.get("failed_count") != 0
    or data.get("skipped_count") != 0
    or missing
    or failed
    or bad_cleanup
):
    if data.get("proof") != expected_proof:
        print(f"LSP proof name is {data.get('proof')}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"LSP proof status is {data.get('status')}", file=sys.stderr)
    if (
        data.get("completed_count") != len(servers)
        or data.get("failed_count") != 0
        or data.get("skipped_count") != 0
    ):
        print(
            f"LSP proof counts are completed_count={data.get('completed_count')} failed_count={data.get('failed_count')} skipped_count={data.get('skipped_count')}",
            file=sys.stderr,
        )
    if missing:
        print(f"LSP proof missing rows: {', '.join(missing)}", file=sys.stderr)
    if failed:
        print(f"LSP proof incomplete rows: {', '.join(failed)}", file=sys.stderr)
    if bad_cleanup:
        print(f"LSP proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "LSP $label proof is present"
  else
    case "$?" in
      66) block "LSP $label proof is missing completed local evidence" ;;
      *) fail "LSP $label proof is unreadable" ;;
    esac
  fi
}

