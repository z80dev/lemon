verify_discord_dm_redacted_proof() {
  local proof_path="${LEMON_DISCORD_DM_REDACTED_PROOF_JSON:-.lemon/proofs/discord-dm-latest.json}"

  if [ ! -f "$proof_path" ]; then
    block "Discord DM redacted proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
passed = {check.get("name") for check in checks if check.get("status") == "completed"}
coverage = data.get("coverage") or {}
cleanup = data.get("cleanup") or {}
safe_reason_label = re.compile(r"^[A-Za-z0-9_.:-]{1,80}$")


def reason_kind(value):
    if not isinstance(value, str) or not value:
        return None

    if safe_reason_label.match(value):
        return value

    return "unsafe_reason_kind_redacted"


def reason_hint(kind):
    if not kind:
        return None

    if "permission_denied" in kind:
        return "provider permissions were denied; enable the API and grant IAM/billing access for the configured provider account"
    if "billing_limit" in kind:
        return "provider billing or quota limit was hit; use a funded project/key or raise quota"
    if "payment_required" in kind:
        return "provider payment is required; fund or upgrade the account"
    if "invalid_request_error" in kind:
        return "provider rejected the request; verify model, voice, output format, and provider options"
    if "provider_http_error" in kind:
        return "provider returned an HTTP error; inspect the sanitized reason and rerun the target provider lane"

    return None


reason_kinds = sorted(
    {
        kind
        for kind in (
            [reason_kind(data.get("reason_kind"))]
            + [reason_kind(check.get("reason_kind")) for check in checks]
        )
        if kind
    }
)
required_cleanup = [
    "includes_raw_bot_tokens",
    "includes_raw_interaction_tokens",
    "includes_raw_application_ids",
    "includes_raw_channel_ids",
    "includes_raw_user_ids",
    "includes_raw_message_bodies",
    "includes_secret_names",
]
bad_cleanup = [key for key in required_cleanup if cleanup.get(key) is not False]

if (
    data.get("status") != "completed"
    or data.get("proof_object") != "lemon.discord_live_matrix"
    or "discord_dm_prompt_round_trip" not in passed
    or coverage.get("contains_dm") is not True
    or "discord_dm_setup_refused" in reason_kinds
    or bad_cleanup
):
    if "discord_dm_prompt_round_trip" not in passed:
        print("Discord DM proof is missing completed round-trip check", file=sys.stderr)
    if coverage.get("contains_dm") is not True:
        print("Discord DM proof is missing DM coverage", file=sys.stderr)
    if "discord_dm_setup_refused" in reason_kinds:
        print("Discord DM proof is a setup refusal, not promotable evidence", file=sys.stderr)
    if bad_cleanup:
        print(f"Discord DM proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"Discord DM proof status is {data.get('status')}", file=sys.stderr)
    if data.get("proof_object") != "lemon.discord_live_matrix":
        print(f"Discord DM proof_object is {data.get('proof_object')}", file=sys.stderr)
    if reason_kinds:
        print(f"Discord DM proof reason_kind: {', '.join(reason_kinds)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord DM redacted proof is present"
  else
    case "$?" in
      66) block "Discord DM redacted proof does not prove a successful DM round trip" ;;
      *) fail "Discord DM redacted proof is unreadable" ;;
    esac
  fi
}

verify_discord_free_response_redacted_proof() {
  local proof_path="${LEMON_DISCORD_FREE_RESPONSE_REDACTED_PROOF_JSON:-.lemon/proofs/discord-free-response-latest.json}"

  if [ ! -f "$proof_path" ]; then
    block "Discord free-response redacted proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
check = next((row for row in checks if row.get("name") == "discord_free_response_trigger_round_trip"), None)
coverage = data.get("coverage") or {}
cleanup = data.get("cleanup") or {}
required_cleanup = [
    "includes_raw_bot_tokens",
    "includes_raw_interaction_tokens",
    "includes_raw_application_ids",
    "includes_raw_channel_ids",
    "includes_raw_user_ids",
    "includes_raw_message_bodies",
    "includes_secret_names",
]
bad_cleanup = [key for key in required_cleanup if cleanup.get(key) is not False]
diagnostics = (check or {}).get("local_channel_diagnostics") or {}
free_response = diagnostics.get("free_response") or {}
trigger_mode = (check or {}).get("trigger_mode") or {}
trigger_cleanup = trigger_mode.get("cleanup") or {}
safe_reason_label = re.compile(r"^[A-Za-z0-9_.:-]{1,80}$")


def reason_kind(value):
    if not isinstance(value, str) or not value:
        return None

    if safe_reason_label.match(value):
        return value

    return "unsafe_reason_kind_redacted"


check_details = check.get("details") if isinstance(check, dict) and isinstance(check.get("details"), dict) else {}
reason_kinds = sorted(
    {
        kind
        for kind in (
            reason_kind(data.get("reason_kind")),
            reason_kind((check or {}).get("reason_kind")),
            reason_kind(check_details.get("reason_kind")),
        )
        if kind
    }
)

if (
    data.get("status") != "completed"
    or data.get("proof_object") != "lemon.discord_live_matrix"
    or not check
    or check.get("status") != "completed"
    or coverage.get("contains_free_response") is not True
    or free_response.get("message_content_intent_declared") is not True
    or trigger_mode.get("mode") != "all"
    or trigger_cleanup.get("mode") != "clear"
    or bad_cleanup
):
    if not check or check.get("status") != "completed":
        print("Discord free-response proof is missing completed trigger round-trip check", file=sys.stderr)
    if coverage.get("contains_free_response") is not True:
        print("Discord free-response proof is missing free-response coverage", file=sys.stderr)
    if free_response.get("message_content_intent_declared") is not True:
        print("Discord free-response proof does not declare Message Content Intent readiness", file=sys.stderr)
    if trigger_mode.get("mode") != "all" or trigger_cleanup.get("mode") != "clear":
        print("Discord free-response proof does not show trigger all with cleanup clear", file=sys.stderr)
    if bad_cleanup:
        print(f"Discord free-response proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"Discord free-response proof status is {data.get('status')}", file=sys.stderr)
    if data.get("proof_object") != "lemon.discord_live_matrix":
        print(f"Discord free-response proof_object is {data.get('proof_object')}", file=sys.stderr)
    if reason_kinds:
        print(f"Discord free-response proof reason_kind: {', '.join(reason_kinds)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord free-response redacted proof is present"
  else
    case "$?" in
      66) block "Discord free-response redacted proof does not prove unmentioned-message delivery with Message Content Intent declared" ;;
      *) fail "Discord free-response redacted proof is unreadable" ;;
    esac
  fi
}

verify_discord_slash_client_click_proof() {
  local proof_path="${LEMON_DISCORD_SLASH_CLIENT_CLICK_PROOF_JSON:-.lemon/proofs/discord-slash-client-click-proof-latest.json}"

  if [ ! -f "$proof_path" ]; then
    block "Discord slash client-click proof artifact is missing: $proof_path (run scripts/live_discord_matrix.py --wait-slash-client-click-proof while clicking a real Discord slash command)"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
passed = {check.get("name") for check in checks if check.get("status") == "completed"}
coverage = data.get("coverage") or {}
cleanup = data.get("cleanup") or {}
safe_reason_label = re.compile(r"^[A-Za-z0-9_.:-]{1,80}$")


def reason_kind(value):
    if not isinstance(value, str) or not value:
        return None

    if safe_reason_label.match(value):
        return value

    return "unsafe_reason_kind_redacted"


reason_kinds = sorted(
    {
        kind
        for kind in (
            [reason_kind(data.get("reason_kind"))]
            + [reason_kind(check.get("reason_kind")) for check in checks]
        )
        if kind
    }
)
required_cleanup = [
    "includes_raw_bot_tokens",
    "includes_raw_interaction_tokens",
    "includes_raw_application_ids",
    "includes_raw_channel_ids",
    "includes_raw_user_ids",
    "includes_raw_message_bodies",
]
bad_cleanup = [key for key in required_cleanup if cleanup.get(key) is not False]

if (
    data.get("status") != "completed"
    or data.get("proof_object") != "lemon.discord_slash_client_click"
    or data.get("proof_scope") != "discord_slash_client_click_observed"
    or coverage.get("real_client_click_proof") is not True
    or (coverage.get("client_click_command_count") or 0) < 1
    or "discord_slash_client_click_observed" not in passed
    or "discord_slash_client_click_safe_mentions" not in passed
    or bad_cleanup
):
    if data.get("status") != "completed":
        print(f"Discord slash client-click proof status is {data.get('status')}", file=sys.stderr)
    if data.get("proof_object") != "lemon.discord_slash_client_click":
        print(f"Discord slash client-click proof_object is {data.get('proof_object')}", file=sys.stderr)
    if data.get("proof_scope") != "discord_slash_client_click_observed":
        print(f"Discord slash client-click proof_scope is {data.get('proof_scope')}", file=sys.stderr)
    if coverage.get("real_client_click_proof") is not True:
        print("Discord slash client-click proof is not marked as real client-click evidence", file=sys.stderr)
    if (coverage.get("client_click_command_count") or 0) < 1:
        print("Discord slash client-click proof has no clicked command count", file=sys.stderr)
    if "discord_slash_client_click_observed" not in passed:
        print("Discord slash client-click observed check is missing", file=sys.stderr)
    if "discord_slash_client_click_safe_mentions" not in passed:
        print("Discord slash client-click safe-mentions check is missing", file=sys.stderr)
    if bad_cleanup:
        print(f"Discord slash client-click proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if reason_kinds:
        print(f"Discord slash client-click proof reason_kind: {', '.join(reason_kinds)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord slash client-click proof is present"
  else
    case "$?" in
      66) block "Discord slash client-click proof does not prove a real safe client click" ;;
      *) fail "Discord slash client-click proof is unreadable" ;;
