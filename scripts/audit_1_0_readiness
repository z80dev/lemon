#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: scripts/audit_1_0_readiness <version> [local-artifact-directory]

Runs the final Lemon 1.0 readiness audit for a CalVer release candidate.

The audit checks:
  - mix.exs version matches <version>
  - CHANGELOG.md has validated release notes for <version>
  - CI/docs policy lint passes
  - canonical local release-candidate test lanes pass
  - public docs site builds, has no high advisory, and has no broken markdown links
  - optional local artifact directory passes manifest and runtime boot verification
  - remote publication preflight reports tag, workflow, and eval secret state
  - public GitHub Release artifacts can be downloaded, verified, and booted
  - provider-backed live eval runs when release eval credentials are present
  - Discord external-sender manual live proof is present when promoting Hermes-channel parity
  - public support and comparison docs keep unresolved Hermes-only surfaces
    outside the stable 1.0 support boundary
  - channel command parity is inventoried and bounded before launch

Exit codes:
  0   all audited gates passed
  1   local readiness failure
  2   usage or tool error
  66  launch-blocking external evidence is missing
EOF
  exit 2
}

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  usage
fi

VERSION="$1"
LOCAL_ARTIFACT_DIR="${2:-}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

ERRORS=0
BLOCKERS=0

pass() {
  echo "ok:      $*"
}

info() {
  echo "info:    $*"
}

fail() {
  echo "fail:    $*" >&2
  ERRORS=$((ERRORS + 1))
}

block() {
  echo "blocked: $*" >&2
  BLOCKERS=$((BLOCKERS + 1))
}

print_blocker_next_steps() {
  cat >&2 <<EOF

Next commands after maintainer approval and required credentials:

  # First publish the release-readiness changes to the default branch.
  # The release and live-eval workflows must exist on GitHub before the tag
  # is pushed or manually dispatched.
  git status --short --branch
  git rev-list --count origin/main..HEAD
  git log --oneline origin/main..HEAD
  test -z "\$(git status --short)" || { echo "refusing to publish with a dirty tree" >&2; exit 1; }
  git log -1 --oneline
  git push origin main

  # Option A: push the tag and let the tag-push workflow create the release.
  git tag v$VERSION
  git push origin v$VERSION

  # Option B: if the tag already exists or the tag-push workflow did not run,
  # manually dispatch the release workflow. Do not run both paths unless
  # intentionally rerunning the release workflow.
  gh workflow run release.yml --ref v$VERSION -f tag=v$VERSION -f channel=stable

  gh run list --workflow release.yml --limit 5
  gh run watch {run-id} --exit-status
  scripts/verify_github_release_artifacts $VERSION

  scripts/test live-eval
  # or:
  gh secret set LEMON_EVAL_API_KEY --repo z80dev/lemon
  gh workflow run live-eval.yml --ref v$VERSION -f iterations=3 -f live_timeout_ms=90000
  gh run list --workflow live-eval.yml --limit 5
  gh run watch {run-id} --exit-status

  # Required before claiming stable Discord/Hermes channel parity.
  scripts/live_discord_matrix.py --channel-id 1475727417372049419 \\
    --bot-token-index 0 \\
    --sender-bot-token-index 1 \\
    --manual-matrix \\
    --reset-session-between-checks \\
    --timeout 300 \\
    --result-path tmp/discord-live-proof.json

  LEMON_DISCORD_LIVE_PROOF_JSON=tmp/discord-live-proof.json \\
    scripts/audit_1_0_readiness $VERSION {downloaded-or-local-artifact-directory}
EOF
}

run_or_fail() {
  local label="$1"
  shift
  local output
  output="$(mktemp)"

  if "$@" >"$output" 2>&1; then
    pass "$label"
  else
    cat "$output" >&2
    fail "$label"
  fi

  rm -f "$output"
}

remote_preflight() {
  local tag="v$VERSION"
  local output

  if git ls-remote --tags origin "$tag*" | grep -q .; then
    pass "remote tag exists for $tag"
  else
    info "remote tag $tag is not present on origin"
  fi

  if ! command -v gh >/dev/null 2>&1; then
    info "gh CLI is unavailable; skipping remote workflow and secret preflight"
    return
  fi

  output="$(mktemp)"

  if gh run list --workflow release.yml --limit 1 >"$output" 2>&1; then
    if [ -s "$output" ]; then
      info "release.yml has remote workflow run history"
    else
      info "release.yml has no remote workflow runs"
    fi
  else
    info "release.yml remote workflow lookup failed: $(tr '\n' ' ' <"$output")"
  fi

  : >"$output"
  if gh run list --workflow live-eval.yml --limit 1 >"$output" 2>&1; then
    if [ -s "$output" ]; then
      info "live-eval.yml has remote workflow run history"
    else
      info "live-eval.yml has no remote workflow runs"
    fi
  else
    info "live-eval.yml remote workflow lookup failed: $(tr '\n' ' ' <"$output")"
  fi

  : >"$output"
  if gh secret list --json name --jq '.[].name' >"$output" 2>&1; then
    if grep -qE '^(LEMON_EVAL_API_KEY|LEMON_EVAL_API_KEY_SECRET|INTEGRATION_API_KEY|INTEGRATION_API_KEY_SECRET|ANTHROPIC_API_KEY)$' "$output"; then
      pass "release-eval repository secret is configured"
    else
      info "no release-eval repository secret found under LEMON_EVAL_API_KEY, LEMON_EVAL_API_KEY_SECRET, INTEGRATION_API_KEY, INTEGRATION_API_KEY_SECRET, or ANTHROPIC_API_KEY"
    fi
  else
    info "release-eval repository secret lookup failed: $(tr '\n' ' ' <"$output")"
  fi

  rm -f "$output"
}

verify_public_support_boundaries() {
  if python3 - <<'PY'
from pathlib import Path
import sys

requirements = {
    "docs/support.md": [
        "Discord support is bounded to the live-proven path",
        "OpenAI-compatible API server behavior",
        "ACP editor integration",
        "automatic filesystem checkpointing or rollback",
        "first-class browser automation",
        "generated media, image analysis, or TTS/voice",
        "production support for third-party plugins",
    ],
    "docs/compare.md": [
        "stable Telegram and Discord text-first support",
        "ACP editor integration or OpenAI-compatible Chat Completions/Responses API",
        "automatic filesystem checkpointing or rollback",
        "first-class browser automation, media generation, image analysis, or voice/TTS",
        "Discord behavior beyond the live-proven text-first and file-delivery boundary",
        "production support for third-party plugins",
    ],
}

missing = []

for path, needles in requirements.items():
    text = Path(path).read_text(encoding="utf-8")
    for needle in needles:
        if needle not in text:
            missing.append(f"{path}: {needle}")

if missing:
    print("missing public support-boundary text:", file=sys.stderr)
    for item in missing:
        print(f"  - {item}", file=sys.stderr)
    sys.exit(1)
PY
  then
    pass "public support boundary docs classify unresolved Hermes-only surfaces"
  else
    fail "public support boundary docs are missing unresolved Hermes-surface classifications"
  fi
}

verify_channel_command_matrix() {
  if python3 - <<'PY'
from pathlib import Path
import sys

path = Path("docs/plans/lemon-channel-command-parity-matrix-2026-05-12.md")

if not path.exists():
    print(f"missing {path}", file=sys.stderr)
    sys.exit(1)

text = path.read_text(encoding="utf-8")
needles = [
    "Stable Telegram text-first command boundary",
    "Preview Discord command boundary",
    "Hermes Messaging Command Comparison",
    "Telegram command support is sufficient for the text-first plus document-delivery",
    "Discord command support is stable only for the live-proven text-first and",
    "Hermes drop-in command parity is not a Lemon 1.0 claim",
    "scripts/live_discord_matrix.py --manual-matrix",
]
missing = [needle for needle in needles if needle not in text]

if missing:
    print("missing command-matrix launch boundary text:", file=sys.stderr)
    for item in missing:
        print(f"  - {item}", file=sys.stderr)
    sys.exit(1)
PY
  then
    pass "channel command parity matrix is present and bounded"
  else
    fail "channel command parity matrix is missing required launch-boundary text"
  fi
}

verify_discord_live_proof() {
  local proof_path="${LEMON_DISCORD_LIVE_PROOF_JSON:-}"

  if [ -z "$proof_path" ]; then
    block "Discord external-sender manual matrix not verified; set LEMON_DISCORD_LIVE_PROOF_JSON to a passing result JSON"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord external-sender manual matrix result file is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
required = {
    "discord_user_inbound_prompt_round_trip",
    "discord_markdown_code_rendering",
    "discord_long_output_chunking",
    "discord_tool_success_failure_rendering",
    "discord_file_delivery",
}
checks = data.get("checks") or []
passed = {check.get("name") for check in checks if check.get("ok") is True}
missing = sorted(required - passed)

if data.get("ok") is not True or missing:
    print(f"missing Discord live checks: {', '.join(missing) if missing else 'overall ok=false'}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord external-sender manual live matrix proof is present"
  else
    case "$?" in
      66) block "Discord external-sender manual matrix result does not prove required checks" ;;
      *) fail "Discord external-sender manual matrix result is unreadable" ;;
    esac
  fi
}

cd "$ROOT"

if ! echo "$VERSION" | grep -qE '^[0-9]{4}\.[0-9]{1,2}\.[0-9]+$'; then
  echo "invalid CalVer version: $VERSION" >&2
  exit 2
fi

MIX_VERSION="$(
  python3 - <<'PY'
import re
from pathlib import Path

match = re.search(r'version:\s*"([^"]+)"', Path("mix.exs").read_text(encoding="utf-8"))
print(match.group(1) if match else "")
PY
)"

if [ "$MIX_VERSION" = "$VERSION" ]; then
  pass "mix.exs version matches $VERSION"
else
  fail "mix.exs version is '$MIX_VERSION', expected '$VERSION'"
fi

run_or_fail "release notes are valid for $VERSION" \
  scripts/prepare_release_notes "$VERSION"

run_or_fail "CI/docs policy lint passes" \
  scripts/lint_ci_docs.sh

run_or_fail "fast test lane passes" \
  scripts/test fast

run_or_fail "quality test lane passes" \
  scripts/test quality

run_or_fail "eval-fast test lane passes" \
  scripts/test eval-fast

run_or_fail "client test lane passes" \
  scripts/test clients

run_or_fail "docs site verifies" \
  scripts/verify_docs_site

verify_public_support_boundaries
verify_channel_command_matrix

if [ -n "$LOCAL_ARTIFACT_DIR" ]; then
  run_or_fail "local artifacts verify and boot at $LOCAL_ARTIFACT_DIR" \
    scripts/verify_release_runtime_boot "$LOCAL_ARTIFACT_DIR"
else
  block "local artifact verification not run; pass the artifact directory as the second argument"
fi

remote_preflight

if command -v gh >/dev/null 2>&1; then
  github_output="$(mktemp)"
  if scripts/verify_github_release_artifacts "$VERSION" >"$github_output" 2>&1; then
    pass "public GitHub Release artifacts verify and boot for v$VERSION"
  else
    github_status="$?"
    cat "$github_output" >&2
    case "$github_status" in
      66) block "public GitHub Release artifacts are not available for v$VERSION" ;;
      *) fail "public GitHub Release artifact verification failed for v$VERSION" ;;
    esac
  fi
  rm -f "$github_output"
else
  block "gh CLI is not available; public GitHub Release artifact verification not run"
fi

if [ -n "${LEMON_EVAL_API_KEY:-}" ] ||
   [ -n "${LEMON_EVAL_API_KEY_SECRET:-}" ] ||
   [ -n "${INTEGRATION_API_KEY:-}" ] ||
   [ -n "${INTEGRATION_API_KEY_SECRET:-}" ] ||
   [ -n "${ANTHROPIC_API_KEY:-}" ]; then
  run_or_fail "provider-backed live eval passes" \
    scripts/test live-eval
else
  block "provider-backed live eval not run; set LEMON_EVAL_API_KEY, LEMON_EVAL_API_KEY_SECRET, INTEGRATION_API_KEY, INTEGRATION_API_KEY_SECRET, or ANTHROPIC_API_KEY"
fi

verify_discord_live_proof

echo ""

if [ "$ERRORS" -gt 0 ]; then
  echo "FAILED: $ERRORS readiness failure(s), $BLOCKERS blocker(s)." >&2
  exit 1
fi

if [ "$BLOCKERS" -gt 0 ]; then
  echo "BLOCKED: $BLOCKERS launch-blocking evidence item(s) missing." >&2
  print_blocker_next_steps
  exit 66
fi

echo "Lemon $VERSION readiness audit passed."
