run_or_fail() {
  local label="$1"
  shift
  local output
  output="$(mktemp)"

  if "$@" >"$output" 2>&1; then
    pass "$label"
  else
    cat "$output" >&2
    fail "$label"
  fi

  rm -f "$output"
}

verify_public_support_boundaries() {
  if python3 - <<'PY'
from pathlib import Path
import sys

requirements = {
    "docs/support.md": [
        "Discord support is bounded to the live-proven path",
        "OpenAI-compatible API server behavior",
        "ACP editor integration",
        "checkpointing for destructive shell commands",
        "first-class browser automation",
        "generated media, image analysis, or TTS/voice",
        "production support for third-party plugins",
    ],
    "docs/compare.md": [
        "stable Telegram and Discord text-first support",
        "ACP editor integration or OpenAI-compatible Chat Completions/Responses API",
        "stable checkpoint/rollback beyond the preview file-tool boundary",
        "first-class browser automation, media generation, image analysis, or voice/TTS",
        "Discord behavior beyond the live-proven text-first and file-delivery boundary",
        "production support for third-party plugins",
    ],
}

missing = []

for path, needles in requirements.items():
    text = Path(path).read_text(encoding="utf-8")
    for needle in needles:
        if needle not in text:
            missing.append(f"{path}: {needle}")

if missing:
    print("missing public support-boundary text:", file=sys.stderr)
    for item in missing:
        print(f"  - {item}", file=sys.stderr)
    sys.exit(1)
PY
  then
    pass "public support boundary docs classify unresolved Hermes-only surfaces"
  else
    fail "public support boundary docs are missing unresolved Hermes-surface classifications"
  fi
}

verify_channel_command_matrix() {
  if python3 - <<'PY'
from pathlib import Path
import sys

path = Path("docs/plans/lemon-channel-command-parity-matrix-2026-05-12.md")

if not path.exists():
    print(f"missing {path}", file=sys.stderr)
    sys.exit(1)

text = path.read_text(encoding="utf-8")
needles = [
    "Stable Telegram text-first command boundary",
    "Preview Discord command boundary",
    "Hermes Messaging Command Comparison",
    "Telegram command support is sufficient for the text-first plus document-delivery",
    "Discord command support is stable only for the live-proven text-first and",
    "Hermes drop-in command parity is not a Lemon 1.0 claim",
    "scripts/live_discord_matrix.py --manual-matrix",
]
missing = [needle for needle in needles if needle not in text]

if missing:
    print("missing command-matrix launch boundary text:", file=sys.stderr)
    for item in missing:
        print(f"  - {item}", file=sys.stderr)
    sys.exit(1)
PY
  then
    pass "channel command parity matrix is present and bounded"
  else
    fail "channel command parity matrix is missing required launch-boundary text"
  fi
}

verify_discord_live_proof() {
  local proof_path="${LEMON_DISCORD_LIVE_PROOF_JSON:-}"

  if [ -z "$proof_path" ]; then
    block "Discord external-sender manual matrix not verified; set LEMON_DISCORD_LIVE_PROOF_JSON to a passing result JSON"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord external-sender manual matrix result file is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
required = {
    "discord_user_inbound_prompt_round_trip",
    "discord_markdown_code_rendering",
    "discord_long_output_chunking",
    "discord_tool_success_failure_rendering",
    "discord_file_delivery",
}
checks = data.get("checks") or []
passed = {check.get("name") for check in checks if check.get("ok") is True}
missing = sorted(required - passed)

if data.get("ok") is not True or missing:
    print(f"missing Discord live checks: {', '.join(missing) if missing else 'overall ok=false'}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord external-sender manual live matrix proof is present"
  else
    case "$?" in
      66) block "Discord external-sender manual matrix result does not prove required checks" ;;
      *) fail "Discord external-sender manual matrix result is unreadable" ;;
    esac
  fi
}

verify_discord_media_slash_proof() {
  local proof_path="${LEMON_DISCORD_MEDIA_SLASH_PROOF_JSON:-}"

  if [ -z "$proof_path" ]; then
    block "Discord /media status slash schema not verified; set LEMON_DISCORD_MEDIA_SLASH_PROOF_JSON to a passing result JSON"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord /media status slash schema result file is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
media = next((check for check in checks if check.get("name") == "discord_media_slash_registration"), None)

if data.get("ok") is not True or not media or media.get("ok") is not True:
    print("Discord /media slash proof is missing or failed", file=sys.stderr)
    sys.exit(66)

subcommands = set(((media.get("summary") or {}).get("subcommands")) or [])
missing = sorted({"status"} - subcommands)

if missing:
    print(f"Discord /media slash proof missing subcommands: {', '.join(missing)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord /media status slash schema proof is present"
  else
    case "$?" in
      66) block "Discord /media status slash schema result does not prove required checks" ;;
      *) fail "Discord /media status slash schema result is unreadable" ;;
    esac
  fi
}

verify_discord_rollback_slash_proof() {
  local proof_path="${LEMON_DISCORD_ROLLBACK_SLASH_PROOF_JSON:-}"

  if [ -z "$proof_path" ]; then
    block "Discord /rollback slash schema not verified; set LEMON_DISCORD_ROLLBACK_SLASH_PROOF_JSON to a passing result JSON"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord /rollback slash schema result file is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
rollback = next((check for check in checks if check.get("name") == "discord_rollback_slash_registration"), None)

if data.get("ok") is not True or not rollback or rollback.get("ok") is not True:
    print("Discord /rollback slash proof is missing or failed", file=sys.stderr)
    sys.exit(66)

summary = rollback.get("summary") or {}
subcommands = set(summary.get("subcommands") or [])
missing_subcommands = sorted({"status", "events", "diff", "restore"} - subcommands)
missing_options = summary.get("missing_options") or {}
wrong_option_types = summary.get("wrong_option_types") or {}

if missing_subcommands or missing_options or wrong_option_types:
    if missing_subcommands:
        print(f"Discord /rollback slash proof missing subcommands: {', '.join(missing_subcommands)}", file=sys.stderr)
    if missing_options:
        print(f"Discord /rollback slash proof missing options: {json.dumps(missing_options, sort_keys=True)}", file=sys.stderr)
    if wrong_option_types:
        print(f"Discord /rollback slash proof has wrong option types: {json.dumps(wrong_option_types, sort_keys=True)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord /rollback slash schema proof is present"
  else
    case "$?" in
      66) block "Discord /rollback slash schema result does not prove required checks" ;;
      *) fail "Discord /rollback slash schema result is unreadable" ;;
    esac
  fi
}

verify_discord_live_redacted_proof() {
  local proof_path="${LEMON_DISCORD_LIVE_REDACTED_PROOF_JSON:-}"

  if [ -z "$proof_path" ]; then
    block "Discord redacted live proof not verified; set LEMON_DISCORD_LIVE_REDACTED_PROOF_JSON to a passing .lemon/proofs artifact"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord redacted live proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
required = {
    "discord_user_inbound_prompt_round_trip",
    "discord_markdown_code_rendering",
    "discord_long_output_chunking",
    "discord_tool_success_failure_rendering",
    "discord_file_delivery",
}
checks = data.get("checks") or []
passed = {check.get("name") for check in checks if check.get("status") == "completed"}
missing = sorted(required - passed)
cleanup = data.get("cleanup") or {}
required_cleanup = [
    "includes_raw_bot_tokens",
    "includes_raw_interaction_tokens",
    "includes_raw_application_ids",
    "includes_raw_channel_ids",
    "includes_raw_user_ids",
    "includes_raw_message_bodies",
    "includes_secret_names",
]
bad_cleanup = [key for key in required_cleanup if cleanup.get(key) is not False]

if (
    data.get("status") != "completed"
    or data.get("proof_object") != "lemon.discord_live_matrix"
    or missing
    or bad_cleanup
):
    if missing:
        print(f"missing redacted Discord live checks: {', '.join(missing)}", file=sys.stderr)
    if bad_cleanup:
        print(f"redacted Discord live proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"redacted Discord live proof status is {data.get('status')}", file=sys.stderr)
    if data.get("proof_object") != "lemon.discord_live_matrix":
        print(f"redacted Discord live proof_object is {data.get('proof_object')}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord redacted live matrix proof is present"
  else
    case "$?" in
      66) block "Discord redacted live matrix proof does not prove required checks and cleanup" ;;
      *) fail "Discord redacted live matrix proof is unreadable" ;;
    esac
  fi
}

verify_discord_media_slash_redacted_proof() {
  local proof_path="${LEMON_DISCORD_MEDIA_SLASH_REDACTED_PROOF_JSON:-}"

  if [ -z "$proof_path" ]; then
    block "Discord /media slash redacted proof not verified; set LEMON_DISCORD_MEDIA_SLASH_REDACTED_PROOF_JSON to a passing .lemon/proofs artifact"
    return
  fi

  if [ ! -f "$proof_path" ]; then
    block "Discord /media slash redacted proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
passed = {check.get("name") for check in checks if check.get("status") == "completed"}
coverage = data.get("coverage") or {}
cleanup = data.get("cleanup") or {}
required_cleanup = [
    "includes_raw_bot_tokens",
    "includes_raw_interaction_tokens",
    "includes_raw_application_ids",
    "includes_raw_channel_ids",
    "includes_raw_user_ids",
    "includes_raw_message_bodies",
    "includes_secret_names",
]
bad_cleanup = [key for key in required_cleanup if cleanup.get(key) is not False]

if (
    data.get("status") != "completed"
    or data.get("proof_object") != "lemon.discord_live_matrix"
    or "discord_media_slash_registration" not in passed
    or coverage.get("contains_media_slash_registration") is not True
    or bad_cleanup
):
    if "discord_media_slash_registration" not in passed:
        print("redacted Discord /media slash proof is missing completed check", file=sys.stderr)
    if coverage.get("contains_media_slash_registration") is not True:
        print("redacted Discord /media slash proof is missing media registration coverage", file=sys.stderr)
    if bad_cleanup:
        print(f"redacted Discord /media slash proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"redacted Discord /media slash proof status is {data.get('status')}", file=sys.stderr)
    if data.get("proof_object") != "lemon.discord_live_matrix":
        print(f"redacted Discord /media slash proof_object is {data.get('proof_object')}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Discord /media slash redacted proof is present"
  else
    case "$?" in
      66) block "Discord /media slash redacted proof does not prove required checks and cleanup" ;;
      *) fail "Discord /media slash redacted proof is unreadable" ;;
    esac
  fi
}

