verify_extension_proof() {
  local label="$1"
  local proof_path="$2"
  local proof_name="$3"
  local required_count="$4"
  local required_rows_csv="$5"
  local redaction_keys_csv="$6"

  if [ ! -f "$proof_path" ]; then
    block "$label proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" "$proof_name" "$required_count" "$required_rows_csv" "$redaction_keys_csv" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
expected_proof = sys.argv[2]
required_count = int(sys.argv[3])
required = set(filter(None, sys.argv[4].split(",")))
redaction_keys = tuple(filter(None, sys.argv[5].split(",")))

data = json.loads(path.read_text(encoding="utf-8"))
checks = data.get("checks") or []
by_name = {
    row.get("name"): row
    for row in checks
    if isinstance(row, dict) and row.get("name")
}
missing = sorted(required - set(by_name))
failed = sorted(
    name
    for name in required & set(by_name)
    if by_name[name].get("status") != "completed"
)
redaction = data.get("redaction") or {}
bad_redaction = [
    key
    for key in redaction_keys
    if redaction.get(key) is not False
]
skipped_count = data.get("skipped_count") or 0

if (
    data.get("proof") != expected_proof
    or data.get("status") != "completed"
    or data.get("completed_count") != required_count
    or data.get("failed_count") != 0
    or skipped_count != 0
    or missing
    or failed
    or bad_redaction
):
    if data.get("proof") != expected_proof:
        print(f"proof name is {data.get('proof')}", file=sys.stderr)
    if data.get("status") != "completed":
        print(f"proof status is {data.get('status')}", file=sys.stderr)
    if data.get("completed_count") != required_count or data.get("failed_count") != 0 or skipped_count != 0:
        print(
            f"proof counts are completed_count={data.get('completed_count')} failed_count={data.get('failed_count')} skipped_count={data.get('skipped_count')}",
            file=sys.stderr,
        )
    if missing:
        print(f"proof missing rows: {', '.join(missing)}", file=sys.stderr)
    if failed:
        print(f"proof incomplete rows: {', '.join(failed)}", file=sys.stderr)
    if bad_redaction:
        print(f"proof has bad redaction flags: {', '.join(bad_redaction)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "$label proof is present"
  else
    case "$?" in
      66) block "$label proof is missing completed local evidence" ;;
      *) fail "$label proof is unreadable" ;;
    esac
  fi
}

