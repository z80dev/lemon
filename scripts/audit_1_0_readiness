verify_browser_proof() {
  local proof_path="${LEMON_BROWSER_PROOF_JSON:-.lemon/proofs/browser-smoke-latest.json}"

  if [ ! -f "$proof_path" ]; then
    block "Browser proof artifact is missing: $proof_path"
    return
  fi

  if python3 - "$proof_path" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
data = json.loads(path.read_text(encoding="utf-8"))
required_tools = {
    "browser_navigate",
    "browser_wait_for_selector",
    "browser_evaluate",
    "browser_hover",
    "browser_select_option",
    "browser_upload_file",
    "browser_download",
    "browser_snapshot",
    "browser_type",
    "browser_click",
    "browser_screenshot",
    "browser_screenshot_include_image",
    "media_analyze_image_local_vision",
    "browser_analyze_local_vision",
    "browser_get_content",
    "browser_events",
    "browser_set_cookies",
    "browser_get_cookies",
    "browser_clear_state",
    "browser_cdp_attach_mode",
}
required_flags = (
    "model_visible_image_included",
    "browser_to_media_vision_completed",
    "browser_wait_for_selector_completed",
    "browser_evaluate_completed",
    "browser_hover_completed",
    "browser_select_option_completed",
    "browser_upload_file_completed",
    "browser_download_completed",
    "browser_analyze_completed",
    "browser_analyze_model_visible_image_included",
    "browser_cdp_attach_completed",
    "browser_navigation_metadata_blocked",
    "browser_navigation_public_route_guarded",
)
cleanup_keys = (
    "contains_raw_sensitive_values",
    "includes_raw_urls",
    "includes_selectors",
    "includes_typed_text",
    "includes_cookie_values",
    "includes_page_text",
    "includes_artifact_paths",
    "includes_raw_paths",
    "includes_screenshot_bytes",
)
tools = set(data.get("exercised_tools") or [])
missing_tools = sorted(required_tools - tools)
false_flags = [key for key in required_flags if data.get(key) is not True]
cleanup = data.get("cleanup") or data.get("progress_cleanup") or {}
bad_cleanup = [key for key in cleanup_keys if cleanup.get(key) is not False]
status = data.get("status") or ("completed" if data.get("result") == "passed" else data.get("result"))
proof = data.get("proof")
proof_scope = data.get("proof_scope")
completed_count = data.get("completed_count") or 0
failed_count = data.get("failed_count") or 0
skipped_count = data.get("skipped_count") or 0
progress_update_count = data.get("progress_update_count") or 0
progress_browser_child_action_count = data.get("progress_browser_child_action_count") or 0

if (
    status != "completed"
    or completed_count < len(required_tools)
    or failed_count != 0
    or skipped_count != 0
    or progress_update_count < len(required_tools) * 2
    or progress_browser_child_action_count < len(required_tools)
    or (proof is not None and proof != "browser_smoke")
    or (proof_scope is not None and proof_scope != "browser_smoke")
    or missing_tools
    or false_flags
    or bad_cleanup
):
    if status != "completed":
        print(f"browser proof status is {status}", file=sys.stderr)
    if completed_count < len(required_tools) or failed_count != 0 or skipped_count != 0:
        print(
            f"browser proof counts are completed_count={data.get('completed_count')} failed_count={data.get('failed_count')} skipped_count={data.get('skipped_count')}",
            file=sys.stderr,
        )
    if progress_update_count < len(required_tools) * 2 or progress_browser_child_action_count < len(required_tools):
        print(
            f"browser progress counts are progress_update_count={data.get('progress_update_count')} progress_browser_child_action_count={data.get('progress_browser_child_action_count')}",
            file=sys.stderr,
        )
    if proof is not None and proof != "browser_smoke":
        print(f"browser proof name is {proof}", file=sys.stderr)
    if proof_scope is not None and proof_scope != "browser_smoke":
        print(f"browser proof_scope is {proof_scope}", file=sys.stderr)
    if missing_tools:
        print(f"browser proof missing tools: {', '.join(missing_tools)}", file=sys.stderr)
    if false_flags:
        print(f"browser proof incomplete flags: {', '.join(false_flags)}", file=sys.stderr)
    if bad_cleanup:
        print(f"browser proof has bad cleanup flags: {', '.join(bad_cleanup)}", file=sys.stderr)
    sys.exit(66)

print("ok")
PY
  then
    pass "Browser proof is present"
  else
    case "$?" in
      66) block "Browser proof is missing completed local evidence" ;;
      *) fail "Browser proof is unreadable" ;;
    esac
  fi
}

