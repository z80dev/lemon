#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'EOF'
usage: scripts/audit_1_0_readiness <version> [local-artifact-directory]

Runs the final Lemon 1.0 readiness audit for a CalVer release candidate.

The audit checks:
  - mix.exs version matches <version>
  - CHANGELOG.md has validated release notes for <version>
  - CI/docs policy lint passes
  - canonical local release-candidate test lanes pass
  - public docs site builds, has no high advisory, and has no broken markdown links
  - local artifact directory passes manifest and runtime boot verification
  - provider-backed live eval runs when release eval credentials are present
  - Discord external-sender manual live proof is present when promoting Hermes-channel parity
  - Discord external-sender redacted proof artifact is present for support/doctor surfaces
  - Discord DM, free-response, and real slash client-click proof artifacts are completed
  - Discord media and rollback slash redacted proof artifacts are present for support/doctor surfaces
  - Discord all-command slash registration proof artifacts are present before broad command claims
  - Telegram and Discord final-answer MEDIA directive delivery proof artifacts are completed
  - Browser local-driver, CDP attach, interaction, state, and redaction proof is completed
  - OpenAI-compatible API local /v1 smoke proof is completed
  - ACP deterministic stdio, external client, and official SDK proofs are completed
  - MCP stdio, Streamable HTTP, and legacy SSE proofs are completed
  - LSP project-fixture and real-repo fixture proofs are completed
  - extension host, WASM telemetry/policy/lifecycle, and registry audit proofs are completed
  - cron diagnostics, runtime restart, and channel-origin proofs are completed
  - provider-backed image, TTS, STT, vision, and video media proofs are completed
  - terminal backend local, local PTY, Docker, and SSH preview proofs are completed
  - public support and comparison docs keep unresolved Hermes-only surfaces
    outside the stable 1.0 support boundary
  - channel command parity is inventoried and bounded before launch

Exit codes:
  0   all audited gates passed
  1   local readiness failure
  2   usage or tool error
  66  launch-blocking live evidence is missing
EOF
  exit 2
}

if [ "$#" -lt 1 ] || [ "$#" -gt 2 ]; then
  usage
fi

VERSION="$1"
LOCAL_ARTIFACT_DIR="${2:-}"
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

ERRORS=0
BLOCKERS=0

pass() {
  echo "ok:      $*"
}

info() {
  echo "info:    $*"
}

fail() {
  echo "fail:    $*" >&2
  ERRORS=$((ERRORS + 1))
}

block() {
  echo "blocked: $*" >&2
  BLOCKERS=$((BLOCKERS + 1))
}

